# Admin SPA backend base URL. Required — startup fails fast when missing
# (no production / same-origin fallback by design, per
# docs/plans/2026-05-11-admin-interface-extraction.md §4.3).
#
# Copy this file to .env (git-ignored) and adjust the URL for your environment:
#
#   cp .env.example .env
#
# Local Mr.Market backend (`server/`) typically listens on port 3000:
PUBLIC_MRM_BACKEND_URL=http://localhost:3000

# Production:
# PUBLIC_MRM_BACKEND_URL=https://api.mrmarket.one
