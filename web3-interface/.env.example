# Mr.Market backend API URL (required)
PUBLIC_MRM_BACKEND_URL=https://api.mrmarket.one
# Reown (WalletConnect) project ID — required at build time.
# Get one at https://cloud.reown.com (formerly cloud.walletconnect.com).
PUBLIC_REOWN_PROJECT_ID=
# Supported vault addresses per chain (optional, for deposit flow)
PUBLIC_ETHEREUM_VAULT_ADDRESS=
