# Copy this file to server/.env.testnet.
# bun run test:system will load server/.env.testnet automatically.

# Optional explicit switch. If omitted, sandbox boot still activates when the
# required sandbox credentials below are present.
CCXT_SANDBOX_ENABLED=true

# Required. Integration suites skip if any of these are missing.
CCXT_SANDBOX_EXCHANGE=okx
CCXT_SANDBOX_API_KEY=your_api_key
CCXT_SANDBOX_SECRET=your_api_secret

# Optional explicit account label for ExchangeInitService lookups.
CCXT_SANDBOX_ACCOUNT_LABEL=testnet

# Optional. Leave blank unless your sandbox exchange account requires them.
CCXT_SANDBOX_PASSWORD=
CCXT_SANDBOX_UID=

# Optional second sandbox account for live-fill tests that need a true counterparty.
CCXT_SANDBOX_ACCOUNT2_LABEL=account2
CCXT_SANDBOX_ACCOUNT2_API_KEY=
CCXT_SANDBOX_ACCOUNT2_SECRET=
CCXT_SANDBOX_ACCOUNT2_PASSWORD=
CCXT_SANDBOX_ACCOUNT2_UID=

# Optional. Defaults shown here match the test helper defaults.
CCXT_SANDBOX_SYMBOL=BTC/USDT
CCXT_SANDBOX_MIN_REQUEST_INTERVAL_MS=100
