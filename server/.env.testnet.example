# Copy this file to server/.env.testnet.
# bun run test:system will load server/.env.testnet automatically.

# Required. Integration suites skip if any of these are missing.
CCXT_SANDBOX_EXCHANGE=okx
CCXT_SANDBOX_API_KEY=your_api_key
CCXT_SANDBOX_SECRET=your_api_secret

# Optional. Leave blank unless your sandbox exchange account requires them.
CCXT_SANDBOX_PASSWORD=
CCXT_SANDBOX_UID=

# Optional. Defaults shown here match the test helper defaults.
CCXT_SANDBOX_SYMBOL=BTC/USDT
CCXT_SANDBOX_MIN_REQUEST_INTERVAL_MS=100
